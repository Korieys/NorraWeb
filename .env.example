# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics (optional in dev, required in prod) ---
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=

# --- Klaviyo ---
# Public key (6-char site ID) — for any future client-side identify calls
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
# Private API key (pk_...) — server-only
KLAVIYO_PRIVATE_API_KEY=pk_...
# Legacy fallback also supported by server routes
KLAVIYO_PRIVATE_KEY=
# List that "Notify me" subscribers + reservations land in
NEXT_PUBLIC_KLAVIYO_LIST_ID=
# OPTIONAL: separate list for confirmed $1 reservations; falls back to the main list
KLAVIYO_RESERVED_LIST_ID=

# --- Stripe (test mode keys) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret (whsec_...) — from `stripe listen` or the Dashboard endpoint config
STRIPE_WEBHOOK_SECRET=whsec_...
